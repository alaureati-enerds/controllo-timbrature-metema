# ============================================================================
# Variabili d'ambiente di PRODUZIONE (Docker).
#
# Copia questo file in `.env.production` e compila i valori. `.env.production`
# NON va committato (è in .gitignore). Genera i segreti con:
#   openssl rand -base64 32
#
# Avvio (passa SEMPRE --env-file, serve anche all'interpolazione di WEB_PORT):
#   docker compose --env-file .env.production -f docker-compose.prod.yml up -d --build
#
# Vedi docs/deploy-docker.md.
# ============================================================================

# --- Database PostgreSQL (containerizzato nel compose) ---
POSTGRES_USER=app
POSTGRES_PASSWORD=cambia-questa-password
POSTGRES_DB=app

# Stringa di connessione usata da Prisma, dal worker e dal seed. In Docker punta
# all'host INTERNO "postgres" sulla 5432 (NON localhost:5433, che è solo per lo
# sviluppo sull'host). Utente/password/DB devono combaciare con i POSTGRES_* qui sopra.
DATABASE_URL="postgresql://app:cambia-questa-password@postgres:5432/app?schema=public"

# --- Porta esposta all'NGINX reverse proxy esterno ---
# Il proxy farà proxy_pass su 127.0.0.1:<WEB_PORT>. Scegli la porta dell'host.
WEB_PORT=3000

# --- Storage dei file (logo, file utente) ---
# Directory dove vengono salvati i file caricati. In Docker corrisponde al
# volume `storage` montato su /app/storage. Default: "storage".
STORAGE_DIR="storage"

# --- Autenticazione (Better Auth) ---
# Segreto per firmare cookie/token. OBBLIGATORIO e robusto in produzione.
BETTER_AUTH_SECRET="genera-un-segreto-casuale"

# URL base PUBBLICO dell'app. OBBLIGATORIO in produzione.
#  - PRODUZIONE dietro proxy con TLS: usa https://<dominio>. I cookie saranno
#    `Secure`, quindi l'NGINX DEVE inoltrare `X-Forwarded-Proto: https`.
#  - TEST IN LOCALE (senza TLS): usa http://localhost:<WEB_PORT> così i cookie
#    NON sono `Secure` e il login funziona su http.
BETTER_AUTH_URL="https://tuo-dominio.it"

# Segreto per cifrare i segreti salvati a DB (es. password SMTP impostata da GUI).
# Necessario se configuri l'SMTP con autenticazione dalla GUI. Non cambiarlo dopo
# averlo usato: invaliderebbe i segreti già cifrati.
SETTINGS_SECRET="genera-un-segreto-casuale"

# --- Invio email ---
# IMPORTANTE per il primo avvio: lascia "console" così il seed (che crea l'admin
# e tenta l'invio di una mail di verifica) non fallisce per SMTP assente. L'admin
# viene comunque marcato come verificato e può accedere subito. Configura poi
# l'SMTP reale da Impostazioni → Email (ha la precedenza) oppure impostando qui
# EMAIL_DRIVER=smtp con i parametri SMTP_*. Vedi docs/email.md.
EMAIL_DRIVER="console"
EMAIL_FROM="Nome App <no-reply@tuo-dominio.it>"
# SMTP_HOST="smtp.example.com"
# SMTP_PORT=587
# SMTP_USER="utente"
# SMTP_PASSWORD="password"
# SMTP_SECURE="false"

# --- Admin iniziale (creato dal seed al primo avvio, idempotente) ---
# Imposta una password FORTE: è l'account con cui farai il primo login.
SEED_ADMIN_EMAIL="admin@tuo-dominio.it"
SEED_ADMIN_PASSWORD="cambia-questa-password-forte"
SEED_ADMIN_NAME="Admin"

# Utente normale di esempio (puoi rimuoverlo se non ti serve in produzione).
SEED_USER_EMAIL="user@tuo-dominio.it"
SEED_USER_PASSWORD="cambia-questa-password-forte"
SEED_USER_NAME="Utente"
