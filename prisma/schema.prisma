// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================================================
// Autenticazione (Better Auth)
// Questi modelli sono gestiti da Better Auth (vedi lib/auth.ts). I campi extra
// `role`, `banned`, `banReason`, `banExpires`, `impersonatedBy` provengono dal
// plugin admin (RBAC + gestione utenti). Il campo `twoFactorEnabled` e il
// modello TwoFactor provengono dal plugin twoFactor (2FA via TOTP). Le password
// sono salvate hashate nel modello Account, non nel modello User.
// ============================================================================

model User {
  id            String   @id
  name          String
  email         String   @unique
  emailVerified Boolean  @default(false)
  image         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Plugin admin (RBAC + moderazione)
  role       String?   @default("user")
  banned     Boolean?  @default(false)
  banReason  String?
  banExpires DateTime?

  // Plugin twoFactor (2FA): true quando l'utente ha attivato e verificato la 2FA
  twoFactorEnabled Boolean? @default(false)

  sessions   Session[]
  accounts   Account[]
  twoFactors TwoFactor[]
  notes      Note[]

  @@map("user")
}

model Session {
  id        String   @id
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Plugin admin: id dell'admin che sta impersonando l'utente
  impersonatedBy String?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  // Hash della password per il provider email+password
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("account")
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime? @default(now())
  updatedAt  DateTime? @updatedAt

  @@map("verification")
}

// Plugin twoFactor: conserva il segreto TOTP e i codici di backup dell'utente
// (cifrati da Better Auth). `verified` indica che il segreto è stato confermato
// con un primo codice valido durante l'attivazione.
model TwoFactor {
  id          String   @id
  secret      String
  backupCodes String
  verified    Boolean? @default(true)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([secret])
  @@index([userId])
  @@map("two_factor")
}

// ============================================================================
// Dominio applicativo
// ============================================================================

/// Modello di esempio: una semplice nota testuale, ora di proprietà di un utente.
/// Dimostra il flusso end-to-end protetto (UI -> route handler autenticato ->
/// service -> Prisma -> Postgres) con autorizzazione per-utente (ownership).
model Note {
  id        String   @id @default(cuid())
  text      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}
