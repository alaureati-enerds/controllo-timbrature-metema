# Credenziali del database PostgreSQL (usate da docker-compose.yml)
POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_DB=app

# Stringa di connessione usata da Prisma
# La porta 5433 sull'host evita conflitti con altri Postgres locali (il container espone comunque 5432 internamente)
DATABASE_URL="postgresql://app:app@localhost:5433/app?schema=public"

# --- Storage dei file (logo, file utente) ---
# Cartella dove il driver filesystem salva i file caricati. Sta FUORI da public/:
# l'accesso passa sempre dalle route autorizzate. In Docker montala come volume
# per renderla persistente. Default: "storage" (relativa alla working dir).
STORAGE_DIR="storage"

# --- Autenticazione (Better Auth) ---
# Segreto per firmare cookie/token. Genera il tuo con: openssl rand -base64 32
BETTER_AUTH_SECRET="genera-un-segreto-casuale"
# URL base dell'app, usato per costruire i link di verifica/reset.
# In SVILUPPO lascialo NON impostato: Better Auth inferisce l'host dalla
# richiesta (porta reale del dev server). Impostalo SOLO in produzione.
# BETTER_AUTH_URL="https://tuo-dominio.it"

# --- Invio email (verifica, reset password, cambio email, ...) ---
# La configurazione email si può fare da GUI (Impostazioni di sistema → Email):
# quella ha la PRECEDENZA. Le variabili qui sotto restano come FALLBACK per i
# campi non impostati dall'interfaccia (utili in CI/Docker o per il bootstrap).
# Vedi docs/email.md.
#
# Segreto per cifrare i segreti salvati a DB (oggi: la password SMTP impostata da
# GUI). Generalo con `openssl rand -base64 32`. Serve solo se configuri l'SMTP
# con autenticazione DALLA GUI; non serve se usi solo le SMTP_* qui sotto.
# SETTINGS_SECRET="genera-un-segreto-casuale"
#
# Driver attivo. Se lo lasci vuoto (e non impostato da GUI): "console" in
# sviluppo (le email finiscono nei log del server) e "smtp" in produzione.
# Forzalo a "smtp" per provare l'invio reale in locale, es. verso Mailpit.
# EMAIL_DRIVER="smtp"
# Mittente di default. Formato: "Nome <indirizzo@dominio>" oppure solo l'indirizzo.
# Obbligatorio quando il driver è "smtp".
EMAIL_FROM="shadcn starter <no-reply@example.com>"
# Server SMTP. SMTP_PASSWORD è un segreto: qui sta in chiaro (da GUI è cifrata).
# Necessari solo con driver "smtp". SMTP_USER/SMTP_PASSWORD sono OPZIONALI:
# lasciale vuote per server senza autenticazione.
#
# VERIFICA IN LOCALE con Mailpit (servizio "mailpit" di docker-compose.yml):
# decommenta queste tre righe + EMAIL_DRIVER sopra, poi `docker compose up -d`.
# Le mail catturate si leggono su http://localhost:8026 (nessun invio reale).
#   EMAIL_DRIVER="smtp"
#   SMTP_HOST="localhost"
#   SMTP_PORT=1026
#
# Esempio per un provider reale (STARTTLS sulla 587, con autenticazione):
SMTP_HOST="smtp.example.com"
SMTP_PORT=587
SMTP_USER="utente"
SMTP_PASSWORD="password"
# "true" = TLS implicito (porta 465); "false" = STARTTLS (porta 587). Mailpit: "false".
SMTP_SECURE="false"

# --- Account iniziali (creati da `npm run db:seed`, idempotente) ---
SEED_ADMIN_EMAIL="admin@example.com"
SEED_ADMIN_PASSWORD="changeme123"
SEED_ADMIN_NAME="Admin"

SEED_USER_EMAIL="user@example.com"
SEED_USER_PASSWORD="changeme123"
SEED_USER_NAME="Utente"
