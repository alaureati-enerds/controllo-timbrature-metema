# Credenziali del database PostgreSQL (usate da docker-compose.yml)
POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_DB=app

# Stringa di connessione usata da Prisma
# La porta 5433 sull'host evita conflitti con altri Postgres locali (il container espone comunque 5432 internamente)
DATABASE_URL="postgresql://app:app@localhost:5433/app?schema=public"

# --- Autenticazione (Better Auth) ---
# Segreto per firmare cookie/token. Genera il tuo con: openssl rand -base64 32
BETTER_AUTH_SECRET="genera-un-segreto-casuale"
# URL base dell'app, usato per costruire i link di verifica/reset.
# In SVILUPPO lascialo NON impostato: Better Auth inferisce l'host dalla
# richiesta (porta reale del dev server). Impostalo SOLO in produzione.
# BETTER_AUTH_URL="https://tuo-dominio.it"

# --- Account iniziali (creati da `npm run db:seed`, idempotente) ---
SEED_ADMIN_EMAIL="admin@example.com"
SEED_ADMIN_PASSWORD="changeme123"
SEED_ADMIN_NAME="Admin"

SEED_USER_EMAIL="user@example.com"
SEED_USER_PASSWORD="changeme123"
SEED_USER_NAME="Utente"
